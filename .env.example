# Required public Supabase config. These are safe to expose to browser code.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Optional Vite build-time aliases for the same public values.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Server-only secret. Never expose this to browser code.
SUPABASE_SERVICE_ROLE_KEY=
